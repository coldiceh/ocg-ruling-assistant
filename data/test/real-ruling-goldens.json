      "expectedVerdictType": "cannot_activate",
      "mustMention": ["不能发动", "没有其他", "返回"],
      "mustNotMention": ["可以发动，天雷把无限泡影返回手牌"],
      "expectedSafetyLevelMax": "RULE-JUDGED",
      "expectedSafetyLevelMin": "RULE-JUDGED",
      "requiredBlockers": ["chain_activated_normal_spell_trap_cannot_return_to_hand_or_deck", "no_applicable_card_for_mandatory_return_effect"],
      "forbiddenBlockers": [],
      "notes": "发动中的通常陷阱不能返回，导致必做处理无可适用卡。"
    },
