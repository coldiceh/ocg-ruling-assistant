{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "illegal-chain-special-win-hypothesis",
      "question": "在我方的结束阶段，我方场上有1只没有素材的【混沌No.88 机关傀儡-灾厄狮子】，对方基本分2500。对方c1发动【雷破】以灾厄狮子为对象，我方c2发动【隐居者的猛毒药】给与对方800伤害。请问在猛毒药的效果处理后会立刻胜利吗，c1的雷破还会处理吗？",
      "expectedVerdictType": "illegal_premise_with_hypothetical",
      "mustMention": ["连锁不成立", "2500", "1700", "不开连锁", "C1不再处理"],
      "mustNotMention": ["雷破正常处理破坏", "等整个连锁处理完才胜利"],
      "expectedSafetyLevelMax": "RULE-JUDGED",
      "expectedSafetyLevelMin": "RULE-JUDGED",
      "requiredBlockers": ["target_protection_prevents_activation", "immediate_special_win_condition_ends_duel"],
      "forbiddenBlockers": [],
      "notes": "原题非法，同时保留对象保护被无效后的假设分支。"
    },
    {
      "id": "activated-trap-no-return-target",
